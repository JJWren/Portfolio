@inject Portfolio.Web.Services.SiteConfig Site

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#151515" />
    <meta property="og:site_name" content="@Site.SiteTitle" />
    <link rel="alternate" type="application/rss+xml" title="@Site.SiteTitle" href="/feed.xml" />
    <base href="/" />
    <ResourcePreloader />
    <script src="@Assets["js/theme.js"]"></script>
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Portfolio.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/x-icon" href="favicon.ico" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["js/prism.js"]" defer></script>
    <script src="@Assets["js/site.js"]" defer></script>
</body>

</html>
