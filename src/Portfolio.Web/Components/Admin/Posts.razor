@page "/admin/posts"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject BlogService BlogPosts
@inject SiteConfig Site

<PageTitle>Posts — Admin — @Site.SiteTitle</PageTitle>

<section class="section">
    <div class="container">
        <p class="eyebrow">Admin</p>
        <div class="admin-head">
            <h1>Blog posts</h1>
            <a class="btn btn-primary" href="/admin/posts/new">New post</a>
        </div>

        <div class="blog-filters">
            <input type="text" placeholder="Search titles…" aria-label="Search posts"
                   @bind="_search" @bind:after="ApplyFiltersAsync" />
            <select aria-label="Filter by status" @bind="_status" @bind:after="ApplyFiltersAsync">
                <option value="">All</option>
                <option value="published">Published</option>
                <option value="draft">Drafts</option>
            </select>
        </div>

        @if (_result is null)
        {
            <p class="muted">Loading…</p>
        }
        else if (_result.TotalCount == 0)
        {
            <p class="muted">@(HasFilters ? "No posts match those filters." : "No posts yet. Write the first one.")</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Updated</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var post in _result.Items)
                        {
                            <tr>
                                <td>
                                    <strong>@post.Title</strong>
                                    <span class="muted mono-small">/blog/@post.Slug</span>
                                </td>
                                <td>
                                    @if (post.IsPublished)
                                    {
                                        <span class="badge badge-published">Published @post.PublishedAt?.ToString("yyyy-MM-dd")</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-draft">Draft</span>
                                    }
                                </td>
                                <td class="muted">
                                    <time datetime="@post.UpdatedAt.ToString("o")" data-local="datetime">
                                        @post.UpdatedAt.ToString("yyyy-MM-dd HH:mm") UTC
                                    </time>
                                </td>
                                <td class="actions">
                                    <a href="/admin/posts/@post.Id/edit">Edit</a>
                                    @if (post.IsPublished)
                                    {
                                        <a href="/blog/@post.Slug">View</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <PagerControls TItem="Portfolio.Web.Data.BlogPost" Result="_result" OnPage="GoToPageAsync" />
        }
    </div>
</section>

@code {
    private PagedResult<Portfolio.Web.Data.BlogPost>? _result;
    private int _page = 1;
    private string _search = string.Empty;
    private string _status = string.Empty;

    private bool HasFilters => !string.IsNullOrWhiteSpace(_search) || _status.Length > 0;

    protected override async Task OnInitializedAsync()
        => await ReloadAsync();

    private async Task ReloadAsync()
    {
        bool? published = _status switch
        {
            "published" => true,
            "draft" => false,
            _ => null,
        };
        _result = await BlogPosts.GetAdminPageAsync(_page, _search, published);
        _page = _result.Page; // service clamps out-of-range pages
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await ReloadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        _page = page;
        await ReloadAsync();
    }
}
