@page "/admin/messages"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject ContactService Contact
@inject SiteConfig Site

<PageTitle>Messages — Admin — @Site.SiteTitle</PageTitle>

<section class="section">
    <div class="container">
        <p class="eyebrow">Admin</p>
        <div class="admin-head">
            <h1>Messages</h1>
        </div>

        <div class="blog-filters">
            <input type="text" placeholder="Search name, email, or subject…" aria-label="Search messages"
                   @bind="_search" @bind:after="ApplyFiltersAsync" />
            <select aria-label="Filter by state" @bind="_state" @bind:after="ApplyFiltersAsync">
                <option value="">All</option>
                <option value="unread">Unread</option>
                <option value="read">Read</option>
            </select>
        </div>

        @if (_result is null)
        {
            <p class="muted">Loading…</p>
        }
        else if (_result.TotalCount == 0)
        {
            <p class="muted">@(HasFilters ? "No messages match those filters." : "The inbox is empty.")</p>
        }
        else
        {
            <ul class="inbox">
                @foreach (var message in _result.Items)
                {
                    <li class="inbox-item @(message.IsRead ? "read" : "unread")">
                        <button class="inbox-summary" @onclick="() => Toggle(message.Id)">
                            <span class="inbox-from">@message.Name</span>
                            <span class="inbox-subject">@message.Subject</span>
                            <time class="inbox-date" datetime="@message.ReceivedAt.ToString("o")" data-local="datetime">
                                @message.ReceivedAt.ToString("yyyy-MM-dd HH:mm") UTC
                            </time>
                            @if (!message.IsRead)
                            {
                                <span class="badge badge-draft">New</span>
                            }
                        </button>
                        @if (_expandedId == message.Id)
                        {
                            <div class="inbox-body">
                                <p class="muted mono-small">
                                    From @message.Name &lt;<a href="mailto:@message.Email">@message.Email</a>&gt;
                                </p>
                                <p class="inbox-text">@message.Body</p>
                                <div class="editor-actions">
                                    <button class="btn btn-ghost"
                                            @onclick="() => SetReadAsync(message, !message.IsRead)">
                                        Mark @(message.IsRead ? "unread" : "read")
                                    </button>
                                    <a class="btn btn-ghost" href="mailto:@message.Email?subject=Re: @message.Subject">Reply by email</a>
                                    <button class="btn btn-ghost btn-danger" @onclick="() => DeleteAsync(message.Id)">Delete</button>
                                </div>
                            </div>
                        }
                    </li>
                }
            </ul>

            <PagerControls TItem="Portfolio.Web.Data.ContactMessage" Result="_result" OnPage="GoToPageAsync" />
        }
    </div>
</section>

@code {
    private PagedResult<Portfolio.Web.Data.ContactMessage>? _result;
    private int _page = 1;
    private string _search = string.Empty;
    private string _state = string.Empty;
    private int? _expandedId;

    private bool HasFilters => _search.Length > 0 || _state.Length > 0;

    protected override async Task OnInitializedAsync()
        => await ReloadAsync();

    private async Task ReloadAsync()
    {
        bool? isRead = _state switch
        {
            "read" => true,
            "unread" => false,
            _ => null,
        };
        _result = await Contact.GetAdminPageAsync(_page, _search, isRead);
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await ReloadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        _page = page;
        await ReloadAsync();
    }

    private void Toggle(int id)
        => _expandedId = _expandedId == id ? null : id;

    private async Task SetReadAsync(Portfolio.Web.Data.ContactMessage message, bool read)
    {
        await Contact.SetReadAsync(message.Id, read);
        await ReloadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        await Contact.DeleteAsync(id);
        _expandedId = null;
        await ReloadAsync();
    }
}
