@page "/admin/projects/new"
@page "/admin/projects/{Id:int}/edit"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject ProjectService ProjectStore
@inject ImageUploadService Uploads
@inject NavigationManager Nav
@inject SiteConfig Site
@inject IJSRuntime JS

<PageTitle>@(_isNew ? "New project" : "Edit project") — Admin — @Site.SiteTitle</PageTitle>

<section class="section">
    <div class="container narrow-form">
        <p class="eyebrow">Admin</p>
        <div class="admin-head">
            <h1>@(_isNew ? "New project" : "Edit project")</h1>
            <a class="btn btn-ghost" href="/admin/projects">Back to projects</a>
        </div>

        @if (_loading)
        {
            <p class="muted">Loading…</p>
        }
        else
        {
            @if (_error is not null)
            {
                <p class="alert" role="alert">@_error</p>
            }

            <label class="field">
                <span>Title</span>
                <input type="text" maxlength="@ProjectRules.TitleMaxLength" @bind="_title" />
            </label>

            <label class="field">
                <span>Summary <span class="muted">short description on the card</span></span>
                <textarea rows="3" maxlength="@ProjectRules.SummaryMaxLength" @bind="_summary"></textarea>
            </label>

            <label class="field">
                <span>Homepage URL <span class="muted">optional</span></span>
                <input type="url" maxlength="@ProjectRules.HomepageUrlMaxLength" @bind="_homepageUrl" placeholder="https://…" />
            </label>

            <label class="field">
                <span>Repo URL <span class="muted">optional</span></span>
                <input type="url" maxlength="@ProjectRules.RepoUrlMaxLength" @bind="_repoUrl" placeholder="https://github.com/…" />
            </label>

            <div class="field">
                <span>Card image <span class="muted">optional — palette placeholder otherwise</span></span>
                <p class="muted mono-small">
                    @ImageUploadService.AllowedTypesDisplay — up to @ImageUploadService.MaxMegabytes MB.
                    Shown at 16:9; 1280×720 or larger recommended. SVG and GIF upload as-is (no crop).
                </p>
                @if (!string.IsNullOrEmpty(_headerImagePath))
                {
                    <div class="upload-preview">
                        <img src="@_headerImagePath" alt="Card image preview" />
                        <button type="button" class="btn btn-ghost" @onclick="() => _headerImagePath = null">Remove</button>
                    </div>
                }
                @if (_cropUnavailable)
                {
                    <InputFile OnChange="OnImageSelected" accept="@ImageUploadService.AcceptList" aria-label="Card image" />
                }
                else
                {
                    <input type="file" id="project-crop-source" accept="@ImageUploadService.AcceptList" aria-label="Card image" />
                }
                <div class="crop-panel" id="project-crop-panel" hidden>
                    <div class="crop-box" id="project-crop-box">
                        <img id="project-crop-image" alt="" draggable="false" />
                    </div>
                    <span class="muted mono-small">
                        Drag to reposition, scroll or slide to zoom. The box is exactly what the project card shows.
                    </span>
                    <div class="crop-controls">
                        <input type="range" id="project-crop-zoom" min="1" max="4" step="0.01" value="1" aria-label="Zoom" />
                        <button type="button" class="btn btn-primary" id="project-crop-apply">Apply crop</button>
                        <button type="button" class="btn btn-ghost" id="project-crop-full">Use full image</button>
                        <button type="button" class="btn btn-ghost" id="project-crop-cancel">Cancel</button>
                    </div>
                </div>
                <InputFile id="project-crop-target" class="crop-hidden" OnChange="OnImageSelected" accept="@ImageUploadService.AcceptList" />
            </div>

            <label class="check-field">
                <input type="checkbox" @bind="_isVisible" />
                <span>Visible on the projects page</span>
            </label>

            <div class="editor-actions">
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">
                    @(_busy ? "Saving…" : "Save")
                </button>
                @if (!_isNew && !_confirmingDelete)
                {
                    <button class="btn btn-ghost btn-danger" @onclick="() => _confirmingDelete = true">Delete</button>
                }
                @if (_confirmingDelete)
                {
                    <span class="confirm-delete">
                        Delete this project permanently?
                        <button class="btn btn-ghost btn-danger" @onclick="DeleteAsync" disabled="@_busy">Yes, delete</button>
                        <button class="btn btn-ghost" @onclick="() => _confirmingDelete = false">Cancel</button>
                    </span>
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter]
    public int? Id { get; set; }

    private bool _isNew => Id is null;
    private bool _loading = true;
    private bool _busy;
    private bool _confirmingDelete;
    private bool _cropInitialized;
    private bool _cropUnavailable;
    private string? _error;

    private Portfolio.Web.Data.Project? _existing;
    private string _title = string.Empty;
    private string _summary = string.Empty;
    private string? _homepageUrl;
    private string? _repoUrl;
    private string? _headerImagePath;
    private bool _isVisible = true;

    protected override async Task OnInitializedAsync()
    {
        if (Id is not null)
        {
            _existing = await ProjectStore.GetByIdAsync(Id.Value);
            if (_existing is null)
            {
                Nav.NavigateTo("/admin/projects");
                return;
            }

            _title = _existing.Title;
            _summary = _existing.Summary;
            _homepageUrl = _existing.HomepageUrl;
            _repoUrl = _existing.RepoUrl;
            _headerImagePath = _existing.HeaderImagePath;
            _isVisible = _existing.IsVisible;
        }

        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The crop DOM only exists once loading finishes, so init on the
        // first render after that rather than strictly on firstRender. The
        // flag is set before awaiting so overlapping renders can't
        // double-bind; if the interop fails the field degrades to a plain
        // uploader instead of being left dead.
        if (!_loading && !_cropInitialized)
        {
            _cropInitialized = true;
            try
            {
                await JS.InvokeVoidAsync("__cropTool.init", "project", ImageUploadService.MaxBytes);
            }
            catch (JSException)
            {
                _cropUnavailable = true;
                StateHasChanged();
            }
        }
    }

    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        try
        {
            _headerImagePath = await Uploads.SaveAsync(e.File);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SaveAsync()
    {
        _error = null;
        _title = _title.Trim();
        _summary = _summary.Trim();
        if (_title.Length == 0)
        {
            _error = "A title is required.";
            return;
        }

        if (!ProjectUrlRules.TryNormalize(_homepageUrl, "Homepage URL", out var homepageUrl, out var urlError)
            || !ProjectUrlRules.TryNormalize(_repoUrl, "Repo URL", out var repoUrl, out urlError))
        {
            _error = urlError;
            return;
        }

        if (ProjectRules.CheckLengths(_title, _summary, _headerImagePath, homepageUrl, repoUrl) is { } lengthError)
        {
            _error = lengthError;
            return;
        }

        _busy = true;
        try
        {
            var project = _existing ?? new Portfolio.Web.Data.Project { Title = _title };
            project.Title = _title;
            project.Summary = _summary;
            project.HomepageUrl = homepageUrl;
            project.RepoUrl = repoUrl;
            project.HeaderImagePath = _headerImagePath;
            project.IsVisible = _isVisible;

            await ProjectStore.SaveAsync(project);
            Nav.NavigateTo("/admin/projects");
        }
        catch (DbUpdateException)
        {
            _error = "Saving failed — the database rejected the project. Check the field lengths, then try again.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (Id is null)
        {
            return;
        }

        _busy = true;
        try
        {
            await ProjectStore.DeleteAsync(Id.Value);
            Nav.NavigateTo("/admin/projects");
        }
        finally
        {
            _busy = false;
        }
    }
}
