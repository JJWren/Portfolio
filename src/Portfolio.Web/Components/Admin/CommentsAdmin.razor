@page "/admin/comments"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject CommentService Comments
@inject SiteConfig Site

<PageTitle>Comments — Admin — @Site.SiteTitle</PageTitle>

<section class="section">
    <div class="container">
        <p class="eyebrow">Admin</p>
        <div class="admin-head">
            <h1>Comments</h1>
        </div>

        <div class="blog-filters">
            <input type="text" placeholder="Search text or author…" aria-label="Search comments"
                   @bind="_search" @bind:after="ApplyFiltersAsync" />
            <select aria-label="Filter by state" @bind="_state" @bind:after="ApplyFiltersAsync">
                <option value="">All states</option>
                <option value="visible">Visible</option>
                <option value="hidden">Hidden</option>
            </select>
            <select aria-label="Filter by post" @bind="_postId" @bind:after="ApplyFiltersAsync">
                <option value="">All posts</option>
                @foreach (var (id, title) in _posts)
                {
                    <option value="@id">@title</option>
                }
            </select>
        </div>

        @if (_result is null)
        {
            <p class="muted">Loading…</p>
        }
        else if (_result.TotalCount == 0)
        {
            <p class="muted">@(HasFilters ? "No comments match those filters." : "No comments yet.")</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Comment</th>
                            <th>Post</th>
                            <th>When</th>
                            <th>State</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var comment in _result.Items)
                        {
                            <tr class="@(comment.IsHidden ? "row-hidden" : null)">
                                <td>
                                    <strong>@(comment.User.DisplayName ?? comment.User.Email)</strong>
                                    @if (comment.IsAnonymous)
                                    {
                                        <span class="badge badge-draft" title="Shown publicly as Anonymous">Anonymous</span>
                                    }
                                    <span class="comment-body-cell">@comment.Body</span>
                                </td>
                                <td><a href="/blog/@comment.BlogPost.Slug">@comment.BlogPost.Title</a></td>
                                <td class="muted">
                                    <time datetime="@comment.CreatedAt.ToString("o")" data-local="datetime">
                                        @comment.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC
                                    </time>
                                </td>
                                <td>
                                    @if (comment.IsHidden)
                                    {
                                        <span class="badge badge-draft">Hidden</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-published">Visible</span>
                                    }
                                </td>
                                <td class="actions">
                                    <button class="link-button" @onclick="() => ToggleHiddenAsync(comment)">
                                        @(comment.IsHidden ? "Unhide" : "Hide")
                                    </button>
                                    <button class="link-button danger" @onclick="() => DeleteAsync(comment.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <PagerControls TItem="Portfolio.Web.Data.Comment" Result="_result" OnPage="GoToPageAsync" />
        }
    </div>
</section>

@code {
    private PagedResult<Portfolio.Web.Data.Comment>? _result;
    private List<(int Id, string Title)> _posts = [];
    private int _page = 1;
    private string _search = string.Empty;
    private string _state = string.Empty;
    private string _postId = string.Empty;

    private bool HasFilters => !string.IsNullOrWhiteSpace(_search) || _state.Length > 0 || _postId.Length > 0;

    protected override async Task OnInitializedAsync()
    {
        _posts = await Comments.GetPostsWithCommentsAsync();
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        bool? hidden = _state switch
        {
            "hidden" => true,
            "visible" => false,
            _ => null,
        };
        int? postId = int.TryParse(_postId, out var parsed) ? parsed : null;
        _result = await Comments.GetAdminPageAsync(_page, _search, hidden, postId);
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await ReloadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        _page = page;
        await ReloadAsync();
    }

    private async Task ToggleHiddenAsync(Portfolio.Web.Data.Comment comment)
    {
        await Comments.SetHiddenAsync(comment.Id, !comment.IsHidden);
        await ReloadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        // Admin path: ownership check bypassed by isAdmin.
        await Comments.DeleteAsync(id, requestingUserId: string.Empty, isAdmin: true);
        await ReloadAsync();
    }
}
