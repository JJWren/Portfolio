@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@inject SiteConfig Site
@inject ReportService Reports
@inject ContactService Contacts

<PageTitle>Admin — @Site.SiteTitle</PageTitle>

<section class="section">
    <div class="container">
        <p class="eyebrow">Admin</p>
        <h1>Dashboard</h1>
        <p class="muted">Manage the content on this site. More arrives as each area is built.</p>
        <div class="admin-cards">
            <a class="card card-link" href="/admin/posts">
                <h3>Blog posts</h3>
                <p class="muted">Write, edit, and publish posts.</p>
            </a>
            <a class="card card-link" href="/admin/projects">
                <h3>Projects</h3>
                <p class="muted">Curate the projects carousel.</p>
            </a>
            <a class="card card-link" href="/admin/comments">
                <h3>Comments</h3>
                <p class="muted">Moderate the conversation.</p>
            </a>
            <a class="card card-link" href="/admin/messages">
                <h3>
                    Messages
                    @if (_unreadMessages > 0)
                    {
                        <span class="badge badge-draft">@_unreadMessages unread</span>
                    }
                </h3>
                <p class="muted">Read contact-form messages.</p>
            </a>
            <a class="card card-link" href="/admin/reports">
                <h3>
                    Reports
                    @if (_openReports > 0)
                    {
                        <span class="badge badge-draft">@_openReports open</span>
                    }
                </h3>
                <p class="muted">Review reported comments and users.</p>
            </a>
        </div>
    </div>
</section>

@code {
    private int _openReports;
    private int _unreadMessages;

    protected override async Task OnInitializedAsync()
    {
        var openReports = Reports.OpenCountAsync();
        var unreadMessages = Contacts.UnreadCountAsync();
        _openReports = await openReports;
        _unreadMessages = await unreadMessages;
    }
}
