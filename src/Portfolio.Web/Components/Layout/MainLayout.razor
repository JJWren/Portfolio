@inherits LayoutComponentBase
@inject SiteConfig Site
@inject ProfileService Profiles
@inject MessageService MessageStore
@inject ReportService Reports
@inject ContactService Contacts

<header class="site-header">
    <div class="container inner">
        <a class="brand" href="/">
            <img class="brand-logo" src="logo.png" alt="" />
            @Site.OwnerName
        </a>
        <button class="nav-burger" type="button" aria-label="Menu" aria-expanded="false"
                aria-controls="site-nav" onclick="__toggleNav(this)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
        <nav class="site-nav" id="site-nav" aria-label="Main">
            <NavLink href="/projects">Projects</NavLink>
            <NavLink href="/blog">Blog</NavLink>
            <NavLink href="/contact">Contact</NavLink>
            <AuthorizeView Roles="Admin">
                <NavLink class="nav-admin" href="/admin">
                    Admin
                    @if (_adminAttentionCount > 0)
                    {
                        <span class="unread-badge" aria-label="@(_adminAttentionCount == 1 ? "1 item needs attention" : $"{_adminAttentionCount} items need attention")">@BadgeLabel.Format(_adminAttentionCount)</span>
                    }
                </NavLink>
            </AuthorizeView>
            <AuthorizeView>
                <Authorized>
                    <a class="nav-profile" href="/profile"
                       title="@(_unreadCount > 0 ? $"Your profile — {_unreadCount} unread message(s)" : "Your profile")">
                        @if (_avatarUrl is not null)
                        {
                            <img class="avatar avatar-sm" src="@_avatarUrl" alt="Your profile" />
                        }
                        else
                        {
                            <span class="avatar avatar-sm avatar-fallback" aria-hidden="true">@_initial</span>
                        }
                        @if (_unreadCount > 0)
                        {
                            <span class="unread-badge" aria-label="@(_unreadCount == 1 ? "1 unread message" : $"{_unreadCount} unread messages")">@BadgeLabel.Format(_unreadCount)</span>
                        }
                    </a>
                    <form class="logout-form" method="post" action="/auth/logout">
                        <AntiforgeryToken />
                        <input type="hidden" name="returnUrl" value="/" />
                        <button class="signout" type="submit"
                                title="Signed in as @(context.User.Identity?.Name)">Sign out</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <NavLink href="/signin">Sign in</NavLink>
                </NotAuthorized>
            </AuthorizeView>
            <button class="theme-toggle" type="button" onclick="__toggleTheme()"
                    title="Switch theme" aria-label="Switch between dark and light theme">
                <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="4" />
                    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
                </svg>
                <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
                </svg>
            </button>
        </nav>
    </div>
</header>

<main>
    @Body
</main>

<footer class="site-footer">
    <div class="footer-strip" aria-hidden="true"></div>
    <div class="container inner">
        <span>© @DateTime.UtcNow.Year @Site.OwnerName</span>
        <nav class="footer-links" aria-label="Social">
            @if (Site.GitHubUrl is not null)
            {
                <a href="@Site.GitHubUrl" rel="me noopener" target="_blank">GitHub</a>
            }
            @if (Site.LinkedInUrl is not null)
            {
                <a href="@Site.LinkedInUrl" rel="me noopener" target="_blank">LinkedIn</a>
            }
            <a href="mailto:@Site.ContactEmail">Email</a>
            @if (Site.SponsorUrl is not null)
            {
                <a class="sponsor-link" href="@Site.SponsorUrl" rel="noopener" target="_blank">
                    <span aria-hidden="true">♥</span> @Site.SponsorText
                </a>
            }
        </nav>
        <nav class="footer-links footer-legal" aria-label="Legal">
            <a href="/terms">Terms</a>
            <a href="/privacy">Privacy</a>
            <a href="https://github.com/JJWren/Portfolio/blob/HEAD/LICENSE"
               rel="noopener" target="_blank" title="This site runs on an open-source project">MIT</a>
        </nav>
    </div>
</footer>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private string? _avatarUrl;
    private string _initial = "?";
    private int _unreadCount;
    private int _adminAttentionCount;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
        {
            return;
        }

        var auth = await AuthState;
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (userId is null)
        {
            return;
        }

        var profile = await Profiles.GetAsync(userId);
        if (profile is not null)
        {
            _avatarUrl = profile.AvatarUrl;
            _initial = profile.PublicName is { Length: > 0 } name
                ? name[..1].ToUpperInvariant()
                : "?";
        }

        _unreadCount = await MessageStore.UnreadCountAsync(userId);

        if (auth.User.IsInRole("Admin"))
        {
            var counts = await Task.WhenAll(Reports.OpenCountAsync(), Contacts.UnreadCountAsync());
            _adminAttentionCount = counts[0] + counts[1];
        }
    }
}
