@page "/blog"
@inject BlogService BlogPosts
@inject MarkdownService Markdown
@inject SiteConfig Site

<PageTitle>Blog — @Site.SiteTitle</PageTitle>

<section class="section page-head">
    <div class="container">
        <p class="eyebrow">Blog</p>
        <h1>Notes &amp; write-ups</h1>
    </div>
</section>

<section class="post-list">
    <div class="container">
        <form class="blog-filters" method="get" action="/blog">
            <input type="text" name="q" value="@Q" placeholder="Search title or description…"
                   aria-label="Search posts" />
            <select name="month" aria-label="Filter by month">
                <option value="">All months</option>
                @foreach (var month in _months)
                {
                    <option value="@month" selected="@(month == Month)">@MonthLabel(month)</option>
                }
            </select>
            @if (!string.IsNullOrEmpty(Tag))
            {
                <input type="hidden" name="tag" value="@Tag" />
            }
            <button class="btn btn-primary" type="submit">Filter</button>
        </form>

        @if (HasActiveFilters)
        {
            <p class="filter-chips">
                @if (!string.IsNullOrEmpty(Q))
                {
                    <a class="filter-chip" href="@BuildHref(1, q: null)">search: "@Q" ✕</a>
                }
                @if (!string.IsNullOrEmpty(Month))
                {
                    <a class="filter-chip" href="@BuildHref(1, month: null)">@MonthLabel(Month) ✕</a>
                }
                @if (!string.IsNullOrEmpty(Tag))
                {
                    <a class="filter-chip" href="@BuildHref(1, tag: null)">tag: @Tag ✕</a>
                }
                <a class="filter-chip clear-all" href="/blog">clear all</a>
            </p>
        }

        @if (_result is null)
        {
            <p class="muted">Loading…</p>
        }
        else if (_result.TotalCount == 0)
        {
            <p class="muted">
                @(HasActiveFilters
                    ? "No posts match those filters — try loosening them."
                    : "Nothing published yet — check back soon.")
            </p>
        }
        else
        {
            @foreach (var post in _result.Items)
            {
                <article class="post-card @(string.IsNullOrEmpty(post.HeaderImagePath) ? null : "has-image")">
                    <div class="post-card-text">
                        <h3><a href="/blog/@post.Slug">@post.Title</a></h3>
                        <p class="post-meta">
                            <time datetime="@post.PublishedAt?.ToString("o")" data-local="date">
                                @post.PublishedAt?.ToString("MMMM d, yyyy")
                            </time>
                            <span aria-hidden="true">·</span>
                            <span>@Markdown.ReadingTimeMinutes(post.BodyMarkdown) min read</span>
                        </p>
                        @if (!string.IsNullOrEmpty(post.Summary))
                        {
                            <p class="post-summary">@post.Summary</p>
                        }
                        @if (post.Tags.Count > 0)
                        {
                            <ul class="tags">
                                @foreach (var tag in post.Tags)
                                {
                                    <li><a href="/blog?tag=@Uri.EscapeDataString(tag)">@tag</a></li>
                                }
                            </ul>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(post.HeaderImagePath))
                    {
                        <a class="post-card-thumb" href="/blog/@post.Slug" tabindex="-1" aria-hidden="true">
                            <img src="@post.HeaderImagePath" alt="" loading="lazy" />
                        </a>
                    }
                </article>
            }

            <Pager TItem="Portfolio.Web.Data.BlogPost" Result="_result" HrefFor="page => BuildHref(page)" />
        }
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "page")]
    public int? PageNumber { get; set; }

    [SupplyParameterFromQuery(Name = "q")]
    public string? Q { get; set; }

    [SupplyParameterFromQuery(Name = "month")]
    public string? Month { get; set; }

    [SupplyParameterFromQuery(Name = "tag")]
    public string? Tag { get; set; }

    private PagedResult<Portfolio.Web.Data.BlogPost>? _result;
    private List<string> _months = [];

    private bool HasActiveFilters =>
        !string.IsNullOrEmpty(Q) || !string.IsNullOrEmpty(Month) || !string.IsNullOrEmpty(Tag);

    protected override async Task OnInitializedAsync()
    {
        _months = await BlogPosts.GetPublishedMonthsAsync();
        _result = await BlogPosts.GetPublishedPageAsync(PageNumber ?? 1, Q, Month, Tag);
    }

    private static string MonthLabel(string month)
        => BlogFilters.TryParseMonth(month, out var start, out _)
            ? start.ToString("MMMM yyyy")
            : month;

    private const string Keep = "\0";

    /// <summary>Builds /blog hrefs preserving filters; pass an explicit null to drop one.</summary>
    private string BuildHref(int page, string? q = Keep, string? month = Keep, string? tag = Keep)
    {
        var query = System.Web.HttpUtility.ParseQueryString(string.Empty);
        var effectiveQ = q == Keep ? Q : q;
        var effectiveMonth = month == Keep ? Month : month;
        var effectiveTag = tag == Keep ? Tag : tag;
        if (page > 1)
        {
            query["page"] = page.ToString();
        }
        if (!string.IsNullOrEmpty(effectiveQ))
        {
            query["q"] = effectiveQ;
        }
        if (!string.IsNullOrEmpty(effectiveMonth))
        {
            query["month"] = effectiveMonth;
        }
        if (!string.IsNullOrEmpty(effectiveTag))
        {
            query["tag"] = effectiveTag;
        }

        var suffix = query.ToString();
        return string.IsNullOrEmpty(suffix) ? "/blog" : $"/blog?{suffix}";
    }
}
