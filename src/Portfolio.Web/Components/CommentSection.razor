@rendermode InteractiveServer
@inject CommentService Comments
@inject ProfileService Profiles
@inject ReportService Reports
@inject NavigationManager Nav

<section class="section comments" id="comments">
    <p class="eyebrow">Comments</p>

    @if (_comments is null)
    {
        <p class="muted">Loading comments…</p>
    }
    else if (_comments.Count == 0)
    {
        <p class="muted">No comments yet — start the conversation.</p>
    }
    else
    {
        <ul class="comment-list">
            @foreach (var comment in _comments)
            {
                <li class="comment">
                    <div class="comment-head">
                        @if (comment.IsAnonymous)
                        {
                            <span class="avatar avatar-fallback avatar-anon" aria-hidden="true">?</span>
                            <span class="comment-author">Anonymous</span>
                        }
                        else if (!string.IsNullOrEmpty(comment.User.AvatarUrl))
                        {
                            <img class="avatar" src="@comment.User.AvatarUrl" alt="" />
                            <span class="comment-author">@comment.User.PublicName</span>
                        }
                        else
                        {
                            <span class="avatar avatar-fallback" aria-hidden="true">@InitialOf(comment.User.PublicName)</span>
                            <span class="comment-author">@comment.User.PublicName</span>
                        }
                        @if (_userId is not null && comment.UserId == _userId)
                        {
                            <span class="comment-you">you</span>
                        }
                        <time class="comment-date" datetime="@comment.CreatedAt.ToString("o")" data-local="datetime">
                            @comment.CreatedAt.ToString("MMM d, yyyy HH:mm") UTC
                        </time>
                        @if (_userId is not null && (_isAdmin || comment.UserId == _userId))
                        {
                            <button class="comment-delete" title="Delete comment"
                                    @onclick="() => DeleteAsync(comment.Id)">Delete</button>
                        }
                        @if (_userId is not null && !_isBanned && comment.UserId != _userId)
                        {
                            <button class="comment-delete" title="Report this comment or its author"
                                    @onclick="() => ToggleReportForm(comment.Id)">Report</button>
                        }
                    </div>
                    <p class="comment-body">@comment.Body</p>

                    @if (_reportedCommentId == comment.Id)
                    {
                        <p class="saved-note" role="status">Thanks — the report is in the moderation queue.</p>
                    }
                    else if (_reportingCommentId == comment.Id)
                    {
                        <div class="report-form">
                            @if (_reportError is not null)
                            {
                                <p class="alert" role="alert">@_reportError</p>
                            }
                            <label class="field">
                                <span>What are you reporting?</span>
                                <select @bind="_reportTarget">
                                    <option value="comment">This comment</option>
                                    <option value="user">This user</option>
                                </select>
                            </label>
                            <label class="field">
                                <span>Reason</span>
                                <select @bind="_reportReason">
                                    <option value="">Choose a reason…</option>
                                    @foreach (var reason in ReportRules.Reasons)
                                    {
                                        <option value="@reason">@reason</option>
                                    }
                                </select>
                            </label>
                            <label class="field">
                                <span>Details <span class="muted">@(_reportReason == ReportRules.OtherReason ? "required" : "optional")</span></span>
                                <textarea rows="2" maxlength="@ReportRules.MaxDetailsLength" @bind="_reportDetails"></textarea>
                            </label>
                            <div class="editor-actions">
                                <button class="btn btn-primary" @onclick="() => SubmitReportAsync(comment.Id)" disabled="@_busy">
                                    @(_busy ? "Sending…" : "Send report")
                                </button>
                                <button class="btn btn-ghost" @onclick="() => _reportingCommentId = null">Cancel</button>
                            </div>
                        </div>
                    }
                </li>
            }
        </ul>

        @if (_comments.Count < _totalComments)
        {
            <button class="btn btn-ghost show-more" @onclick="ShowMoreAsync" disabled="@_busy">
                Show more (@(_totalComments - _comments.Count) remaining)
            </button>
        }
    }

    @if (_userId is not null && _isBanned)
    {
        <p class="alert" role="alert">
            Your account is currently restricted from commenting.
            Check <a href="/messages">your messages</a> for details.
        </p>
    }
    else if (_userId is not null)
    {
        <div class="comment-form">
            @if (_error is not null)
            {
                <p class="alert" role="alert">@_error</p>
            }
            <label class="field">
                <span>Add a comment</span>
                <textarea rows="4" maxlength="@CommentRules.MaxLength" @bind="_draft"></textarea>
            </label>
            <label class="check-field">
                <input type="checkbox" @bind="_postAnonymously" />
                <span>Post anonymously <span class="muted">(the site owner can still see it's you)</span></span>
            </label>
            <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@_busy">
                @(_busy ? "Posting…" : "Post comment")
            </button>
        </div>
    }
    else
    {
        <p class="comment-signin">
            <a href="/signin?returnUrl=@Uri.EscapeDataString($"/blog/{PostSlug}#comments")">Sign in</a>
            to join the conversation.
        </p>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public int PostId { get; set; }

    [Parameter, EditorRequired]
    public required string PostSlug { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private List<Portfolio.Web.Data.Comment>? _comments;
    // Own comments posted this session that sit beyond the loaded window;
    // shown appended at the end and absorbed once the window reaches them.
    private readonly List<Portfolio.Web.Data.Comment> _appendedOwn = [];
    private Portfolio.Web.Data.ApplicationUser? _profile;
    private int _visibleTake = PageSizes.Comments;
    private int _totalComments;
    private string? _userId;
    private bool _isAdmin;
    private bool _isBanned;
    private string _draft = string.Empty;
    private bool _postAnonymously;
    private string? _error;
    private bool _busy;

    private int? _reportingCommentId;
    private int? _reportedCommentId;
    private string _reportTarget = "comment";
    private string _reportReason = string.Empty;
    private string _reportDetails = string.Empty;
    private string? _reportError;

    private static string InitialOf(string name)
        => (name.Length > 0 ? name[..1] : "?").ToUpperInvariant();

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var auth = await AuthState;
            _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            _isAdmin = auth.User.IsInRole("Admin");
        }

        if (_userId is not null)
        {
            _profile = await Profiles.GetAsync(_userId);
            _postAnonymously = _profile?.PostAnonymouslyByDefault ?? false;
            _isBanned = _profile?.IsBanned ?? false;
        }

        await LoadCommentsAsync();
    }

    private async Task SubmitAsync()
    {
        if (_userId is null)
        {
            return;
        }

        _busy = true;
        try
        {
            var (comment, error) = await Comments.AddAsync(PostId, _userId, _draft, _postAnonymously);
            _error = error;
            if (comment is not null)
            {
                _draft = string.Empty;
                // The new comment sorts last (beyond the loaded window on long
                // threads); append it locally instead of loading the whole thread.
                if (_profile is not null)
                {
                    comment.User = _profile;
                    _appendedOwn.Add(comment);
                }
                await LoadCommentsAsync();
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task LoadCommentsAsync()
    {
        var (items, total) = await Comments.GetVisibleForPostWindowAsync(PostId, _visibleTake);
        _appendedOwn.RemoveAll(a => items.Any(i => i.Id == a.Id)); // absorbed by the window
        _comments = [.. items, .. _appendedOwn];
        _totalComments = total;
    }

    private async Task ShowMoreAsync()
    {
        if (_busy)
        {
            return;
        }

        _busy = true;
        try
        {
            _visibleTake += PageSizes.Comments;
            await LoadCommentsAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private void ToggleReportForm(int commentId)
    {
        _reportError = null;
        _reportedCommentId = null;
        if (_reportingCommentId == commentId)
        {
            _reportingCommentId = null;
            return;
        }

        _reportingCommentId = commentId;
        _reportTarget = "comment";
        _reportReason = string.Empty;
        _reportDetails = string.Empty;
    }

    private async Task SubmitReportAsync(int commentId)
    {
        if (_userId is null)
        {
            return;
        }

        _busy = true;
        try
        {
            var targetType = _reportTarget == "user"
                ? Portfolio.Web.Data.ReportTargetType.User
                : Portfolio.Web.Data.ReportTargetType.Comment;
            var (report, error) = await Reports.CreateAsync(
                _userId, commentId, targetType, _reportReason, _reportDetails);
            _reportError = error;
            if (report is not null)
            {
                _reportingCommentId = null;
                _reportedCommentId = commentId;
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync(int commentId)
    {
        if (_userId is null)
        {
            return;
        }

        await Comments.DeleteAsync(commentId, _userId, _isAdmin);
        _appendedOwn.RemoveAll(a => a.Id == commentId);
        await LoadCommentsAsync();
    }
}
