# ── Site identity ────────────────────────────────────────────────
# These personalize the site; no personal details live in code.
SITE_OWNER_NAME=Jane Developer
SITE_TITLE=Jane Developer — Portfolio
SITE_TAGLINE=Full-stack developer building useful things.
# Optional about-section text; use \n between paragraphs. Hidden when blank.
SITE_ABOUT=I build web apps and developer tooling.\nOff hours I tinker with my home lab.
# Optional comma-separated skill chips shown next to the about text.
SITE_SKILLS=C#,ASP.NET Core,PostgreSQL,Docker,TypeScript

# ── Contact & social links ───────────────────────────────────────
CONTACT_EMAIL=you@example.com
# Optional; leave blank to hide from the site.
CONTACT_PHONE=
LINKEDIN_URL=https://www.linkedin.com/in/your-handle/
# Drives the "see all my work on GitHub" link on the Projects page.
GITHUB_URL=https://github.com/your-handle

# ── Admin access ─────────────────────────────────────────────────
# Comma-separated. Users whose OAuth email matches get the Admin role.
ADMIN_EMAILS=you@example.com

# ── Database (compose wires the connection string automatically) ─
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me

# ── Web ──────────────────────────────────────────────────────────
WEB_PORT=8080

# ── SMTP (contact form email delivery) ───────────────────────────
# Messages are always stored in the database; SMTP is how you get
# notified. Leave HOST blank to disable email sending.
SMTP__HOST=smtp.gmail.com
SMTP__PORT=587
SMTP__USER=you@example.com
SMTP__PASSWORD=app-password-here
SMTP__FROM=you@example.com

# ── OAuth sign-in providers ──────────────────────────────────────
# Only providers with BOTH client id and secret set are enabled and
# shown on the sign-in page. Callback URLs to register:
#   GitHub:  https://your-domain/signin-github
#   Google:  https://your-domain/signin-google
#   Discord: https://your-domain/signin-discord
OAUTH__GITHUB__CLIENTID=
OAUTH__GITHUB__CLIENTSECRET=
OAUTH__GOOGLE__CLIENTID=
OAUTH__GOOGLE__CLIENTSECRET=
OAUTH__DISCORD__CLIENTID=
OAUTH__DISCORD__CLIENTSECRET=

# ── Optional features ────────────────────────────────────────────
# Populate sample posts/projects on first run so the site isn't empty.
SEED_DEMO_DATA=false
# Canonical site origin used in the RSS feed, sitemap, and robots.txt.
# Falls back to the request host when blank.
PUBLIC_BASE_URL=
